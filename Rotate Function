class Solution {
    public int maxRotateFunction(int[] nums) {
        int n = nums.length;
        int ans = Integer.MIN_VALUE, total = 0, f = 0;
        
        for(int i = 0; i < n; i++){
            total += nums[i];
            f += i * nums[i];
        }

        for(int i = n - 1; i >= 0; i--){
            f += total;
            f -= n * nums[i];
            ans = Math.max(ans, f);
        }

        return ans;
    }
}
